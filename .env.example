# ── App ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173        # prod: https://your-frontend.vercel.app

# ── Database ───────────────────────────────────────────────
# Dev: leave empty → uses SQLite (data/app.db)
# Prod (Railway): set to the PostgreSQL URL provided by Railway
DATABASE_URL=                             # postgresql+asyncpg://user:pass@host:5432/db

# ── JWT ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string   # generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Google OAuth (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Stripe (optional) ──────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# ── Groq (free cloud LLM fallback) ─────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Email / SMTP ────────────────────────────────────────────
# Gmail: enable 2FA then generate an App Password at
#   https://myaccount.google.com/apppasswords
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=you@gmail.com
MAIL_FROM_NAME=AI Shorts Generator
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# Set to true during local dev to skip SMTP and log emails to console
MAIL_SUPPRESS_SEND=true

# ── Uvicorn (prod tuning) ───────────────────────────────────
UVICORN_WORKERS=2                         # increase on bigger Railway instances
