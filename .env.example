# ── App ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173        # prod: https://your-frontend.vercel.app

# ── Database ───────────────────────────────────────────────
# Dev: leave empty → uses SQLite (data/app.db)
# Prod (Railway): set to the PostgreSQL URL provided by Railway
DATABASE_URL=                             # postgresql+asyncpg://user:pass@host:5432/db

# ── JWT ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string   # generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Google OAuth (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Standard
STRIPE_STANDARD_MONTHLY_PRICE_ID=price_...
STRIPE_STANDARD_YEARLY_PRICE_ID=price_...

# Pro
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Pro+
STRIPE_PROPLUS_MONTHLY_PRICE_ID=price_...
STRIPE_PROPLUS_YEARLY_PRICE_ID=price_...

# Frontend-exposed price ids (example) — the React/Vite app expects these keys
# You can copy these into your local `.env` or set them in your deployment env.
REACT_APP_STRIPE_TWITCH_STANDARD_MONTHLY=price_1TFkihEjLhnJfUeo01AH9DUk
REACT_APP_STRIPE_TWITCH_STANDARD_YEARLY=price_1TFkk3EjLhnJfUeooCZ04j4u
REACT_APP_STRIPE_TWITCH_PRO_MONTHLY=price_1TFkkvEjLhnJfUeoHzUpXQGR
REACT_APP_STRIPE_TWITCH_PRO_YEARLY=price_1TFklaEjLhnJfUeotfuxMQWR
REACT_APP_STRIPE_TWITCH_PROPLUS_MONTHLY=price_1TFkmIEjLhnJfUeoxJi8jNVI
REACT_APP_STRIPE_TWITCH_PROPLUS_YEARLY=price_1TFknbEjLhnJfUeo4taraTmO

REACT_APP_STRIPE_COMBO_STANDARD_MONTHLY=price_1TFkoFEjLhnJfUeo0n9ujCCk
REACT_APP_STRIPE_COMBO_STANDARD_YEARLY=price_1TFkomEjLhnJfUeoG9ofsz7t
REACT_APP_STRIPE_COMBO_PRO_MONTHLY=price_1TFkpHEjLhnJfUeopkqsxjDq
REACT_APP_STRIPE_COMBO_PRO_YEARLY=price_1TFkqEEjLhnJfUeoDRDmRnTp
REACT_APP_STRIPE_COMBO_PROPLUS_MONTHLY=price_1TFkqmEjLhnJfUeonz3yYclY
REACT_APP_STRIPE_COMBO_PROPLUS_YEARLY=price_1TFkrIEjLhnJfUeoVAdWBWwU

# ── Groq (free cloud LLM) ──────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Whisper ─────────────────────────────────────────────────
# Local dev: base | Prod (Railway): tiny  (saves ~300MB RAM)
WHISPER_MODEL=tiny

# ── yt-dlp / YouTube cookies (EJS solver) -------------------------
# How/when the app should enable yt-dlp JS runtimes and remote components:
# Options: always | when_cookies | on_error
#   - always: always pass --js-runtimes / --remote-components
#   - when_cookies: only pass the flags when cookies are provided (default)
#   - on_error: try without flags first, then retry with flags if a JS challenge is detected
YTDLP_ENABLE_JS=when_cookies
YTDLP_JS_RUNTIMES=node
YTDLP_REMOTE_COMPONENTS=ejs:npm

# YouTube cookies (preferred: mount a file via your secret manager):
# YOUTUBE_COOKIES_FILE=/run/secrets/youtube_cookies.txt
# Or provide base64-encoded cookies (less preferred):
# YOUTUBE_COOKIES_B64=<base64-encoded-cookies>

# ── Email / SMTP ────────────────────────────────────────────
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=you@gmail.com
MAIL_FROM_NAME=AI Shorts Generator
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_SUPPRESS_SEND=false


# ── Uvicorn (prod tuning) ───────────────────────────────────
UVICORN_WORKERS=2                         # increase on bigger Railway instances
