# ── App ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173        # prod: https://your-frontend.vercel.app

# ── Database ───────────────────────────────────────────────
# Dev: leave empty → uses SQLite (data/app.db)
# Prod (Railway): set to the PostgreSQL URL provided by Railway
DATABASE_URL=                             # postgresql+asyncpg://user:pass@host:5432/db

# ── JWT ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string   # generate: python -c "import secrets; print(secrets.token_hex(32))"

# ── Google OAuth (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Standard
STRIPE_STANDARD_MONTHLY_PRICE_ID=price_...
STRIPE_STANDARD_YEARLY_PRICE_ID=price_...

# Pro
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_YEARLY_PRICE_ID=price_...

# Pro+
STRIPE_PROPLUS_MONTHLY_PRICE_ID=price_...
STRIPE_PROPLUS_YEARLY_PRICE_ID=price_...

# ── Groq (free cloud LLM) ──────────────────────────────────
# Get a free API key at https://console.groq.com
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# ── Whisper ─────────────────────────────────────────────────
# Local dev: base | Prod (Railway): tiny  (saves ~300MB RAM)
WHISPER_MODEL=tiny

# ── Email / SMTP ────────────────────────────────────────────
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=you@gmail.com
MAIL_FROM_NAME=AI Shorts Generator
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
MAIL_SUPPRESS_SEND=false


# ── Uvicorn (prod tuning) ───────────────────────────────────
UVICORN_WORKERS=2                         # increase on bigger Railway instances
