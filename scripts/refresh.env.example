# Exemple d'env pour exécuter le refresher Playwright en one-off
# Copiez ce fichier en tant que 'scripts/refresh.env' ou collez les variables
# dans l'interface d'environnement de votre hébergeur (Railway, Heroku, etc.).

# Activer le rafraîchissement automatique (laisse le backend appeler le script si nécessaire)
YOUTUBE_ENABLE_AUTO_REFRESH=true

# Chemin vers le profil persistant Playwright/Chromium contenant la session Google/YouTube
# Doit être un répertoire persistant accessible en écriture par le processus.
YOUTUBE_BROWSER_PROFILE_DIR=/data/youtube_browser_profile

# Où écrire le fichier cookies compatible yt-dlp
YOUTUBE_AUTO_REFRESH_OUT=secrets/youtube_cookies.txt

# Headless en production ? true|false
YOUTUBE_AUTO_REFRESH_HEADLESS=true

# URL canary (vidéo connue qui devrait fonctionner)
YOUTUBE_AUTO_REFRESH_CANARY=https://www.youtube.com/watch?v=recHgNtlUjc

# Chemin vers yt-dlp (si non dans PATH)
#YT_DLP_PATH=yt-dlp

# NOTE: ne définissez pas YOUTUBE_COOKIES_B64 ni les PART_* si vous voulez
# que le backend/pré-refresher utilise le mécanisme Playwright ci-dessus.
